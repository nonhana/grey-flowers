{
  "prettier": {
    "allowed": false
  },
  "format_on_save": "on",
  "code_actions_on_format": {
    "source.fixAll.eslint": true,
    "source.organizeImports": false
  },
  "lsp": {
    "eslint": {
      "settings": {
        "rulesCustomizations": [
          {
            "rule": "style/*",
            "severity": "off",
            "fixable": true
          },
          {
            "rule": "format/*",
            "severity": "off",
            "fixable": true
          },
          {
            "rule": "*-indent",
            "severity": "off",
            "fixable": true
          },
          {
            "rule": "*-spacing",
            "severity": "off",
            "fixable": true
          },
          {
            "rule": "*-spaces",
            "severity": "off",
            "fixable": true
          },
          {
            "rule": "*-order",
            "severity": "off",
            "fixable": true
          },
          {
            "rule": "*-dangle",
            "severity": "off",
            "fixable": true
          },
          {
            "rule": "*-newline",
            "severity": "off",
            "fixable": true
          },
          {
            "rule": "*quotes",
            "severity": "off",
            "fixable": true
          },
          {
            "rule": "*semi",
            "severity": "off",
            "fixable": true
          }
        ]
      }
    }
  }
}
